{
  "name": "pihub",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "Local-first operational runtime for executable AI sub-agents (Pi-first).",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run apps/cli/src/cli.ts",
    "build": "bun build apps/cli/src/cli.ts --compile --outfile dist/pihub",
    "test": "bunx vitest run",
    "test:watch": "bunx vitest",
    "typecheck": "tsc --noEmit",
    "lint": "bunx oxlint",
    "format": "bunx prettier --write .",
    "format:check": "bunx prettier --check ."
  },
  "devDependencies": {
    "@effect/vitest": "^0.29.0",
    "@types/bun": "latest",
    "oxlint": "^0.15.0",
    "prettier": "^3.3.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
